@page "/basket"
@attribute [Authorize]
@inject IBasketService BasketService
@inject NavigationManager Nav

<PageTitle>Basket — B2B Platform</PageTitle>

<div class="page-header">
    <div>
        <h1>Basket</h1>
        <p>Review your selected items before placing an order.</p>
    </div>
</div>

<ErrorAlert Message="@_error" />
<SuccessAlert Message="@_success" />

@if (_loading)
{
    <LoadingSpinner Message="Loading basket…" />
}
else if (_basket is null || _basket.Items.Count == 0)
{
    <div class="b2b-card">
        <div class="empty-state">
            <div class="empty-icon"><i class="bi bi-cart-x"></i></div>
            <h5>Your basket is empty</h5>
            <p>Add products from the product catalog to get started.</p>
            <a href="/products" class="btn btn-primary">Browse Products</a>
        </div>
    </div>
}
else
{
    <div class="row g-3">
        <div class="col-lg-8">
            <div class="b2b-card p-0 overflow-hidden">
                <div class="p-3 border-bottom">
                    <h6 class="fw-semibold mb-0">
                        @_basket.Items.Count item@(_basket.Items.Count == 1 ? "" : "s") in your basket
                    </h6>
                </div>
                @foreach (var item in _basket.Items)
                {
                    <div class="p-3 border-bottom d-flex align-items-center gap-3">
                        <div class="stat-icon flex-shrink-0" style="background:#eef0fd;width:48px;height:48px;">
                            <i class="bi bi-box-seam" style="color:#4361ee;font-size:1.1rem;"></i>
                        </div>
                        <div class="flex-grow-1">
                            <div class="fw-semibold">@item.ProductName</div>
                            <div class="text-muted small">SKU: @item.Sku · @item.UnitPrice.ToString("C") each</div>
                        </div>

                        <!-- Quantity control -->
                        <div class="input-group" style="width:120px;">
                            <button class="btn btn-sm btn-outline-secondary"
                                    @onclick="() => UpdateQty(item, item.Quantity - 1)">−</button>
                            <input type="number" class="form-control form-control-sm text-center"
                                   value="@item.Quantity"
                                   @onchange="e => UpdateQty(item, int.TryParse(e.Value?.ToString(), out var q) ? q : item.Quantity)"
                                   min="1" />
                            <button class="btn btn-sm btn-outline-secondary"
                                    @onclick="() => UpdateQty(item, item.Quantity + 1)">+</button>
                        </div>

                        <div class="fw-bold text-end" style="min-width:80px;">
                            @item.SubTotal.ToString("C")
                        </div>

                        <button class="btn btn-sm btn-link text-danger p-0"
                                @onclick="() => RemoveItem(item.ProductId)">
                            <i class="bi bi-trash"></i>
                        </button>
                    </div>
                }

                <div class="p-3 d-flex justify-content-end">
                    <button class="btn btn-sm btn-outline-danger" @onclick="ClearBasket">
                        <i class="bi bi-cart-x me-1"></i> Clear Basket
                    </button>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="b2b-card p-4">
                <h6 class="fw-semibold mb-3">Summary</h6>
                <dl class="row small mb-3">
                    <dt class="col-7 text-muted">Items</dt>
                    <dd class="col-5 text-end">@_basket.TotalItems</dd>
                    <dt class="col-7 text-muted">Total</dt>
                    <dd class="col-5 text-end fw-bold">@_basket.TotalAmount.ToString("C")</dd>
                </dl>
                <a href="/orders/create" class="btn btn-primary w-100 fw-semibold py-2">
                    <i class="bi bi-bag-check me-2"></i> Place Order
                </a>
                <a href="/products" class="btn btn-outline-secondary w-100 mt-2">
                    <i class="bi bi-arrow-left me-2"></i> Continue Shopping
                </a>
            </div>
        </div>
    </div>
}

@code {
    private Models.Basket.BasketDto? _basket;
    private bool _loading = true;
    private string? _error;
    private string? _success;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _basket = await BasketService.GetBasketAsync();
        _loading = false;
    }

    private async Task UpdateQty(Models.Basket.BasketItemDto item, int qty)
    {
        if (qty < 1) return;
        var ok = await BasketService.UpdateItemAsync(item.ProductId, qty);
        if (ok) await LoadAsync();
        else _error = "Failed to update quantity.";
    }

    private async Task RemoveItem(Guid productId)
    {
        var ok = await BasketService.RemoveItemAsync(productId);
        if (ok) await LoadAsync();
        else _error = "Failed to remove item.";
    }

    private async Task ClearBasket()
    {
        var ok = await BasketService.ClearBasketAsync();
        if (ok)
        {
            _success = "Basket cleared.";
            _basket = null;
        }
        else _error = "Failed to clear basket.";
    }
}

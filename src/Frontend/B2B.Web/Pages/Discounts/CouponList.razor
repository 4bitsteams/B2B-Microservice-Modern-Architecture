@page "/coupons"
@attribute [Authorize(Roles = "TenantAdmin,SuperAdmin")]
@inject IDiscountService DiscountService

<PageTitle>Coupons — B2B Platform</PageTitle>

<div class="page-header">
    <div>
        <h1>Coupons</h1>
        <p>Manage redemption codes for your customers.</p>
    </div>
    <button class="btn btn-primary d-flex align-items-center gap-2" @onclick="() => _showCreate = true">
        <i class="bi bi-plus-lg"></i> New Coupon
    </button>
</div>

<ErrorAlert Message="@_error" />
<SuccessAlert Message="@_success" />

@if (_loading)
{
    <LoadingSpinner Message="Loading coupons…" />
}
else if (_coupons?.Items.Count == 0)
{
    <div class="b2b-card">
        <div class="empty-state">
            <div class="empty-icon"><i class="bi bi-ticket-perforated"></i></div>
            <h5>No coupons yet</h5>
            <p>Create coupon codes to offer discounts to your customers.</p>
            <button class="btn btn-primary" @onclick="() => _showCreate = true">Create Coupon</button>
        </div>
    </div>
}
else
{
    <div class="table-b2b">
        <table class="table mb-0">
            <thead>
                <tr>
                    <th>Code</th>
                    <th>Name</th>
                    <th>Value</th>
                    <th>Usage</th>
                    <th>Expires</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in _coupons!.Items)
                {
                    <tr>
                        <td>
                            <code class="px-2 py-1 rounded fw-bold"
                                  style="background:#eef0fd;color:#4361ee;font-size:0.85rem;">
                                @c.Code
                            </code>
                        </td>
                        <td class="fw-semibold">@c.Name</td>
                        <td class="fw-semibold">
                            @(c.Type == "Percentage" ? $"{c.Value}%" : c.Value.ToString("C"))
                        </td>
                        <td class="text-muted">@c.UsageCount / @c.MaxUsageCount</td>
                        <td class="text-muted small">
                            @(c.ExpiresAt?.ToString("MMM d, yyyy") ?? "No expiry")
                        </td>
                        <td><StatusBadge Status="@(c.IsActive ? "active" : "inactive")" /></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <Pagination CurrentPage="_page"
                TotalPages="_coupons.TotalPages"
                TotalCount="_coupons.TotalCount"
                OnPageChanged="OnPageChanged" />
}

<!-- Create Coupon Modal -->
@if (_showCreate)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <div class="modal-header border-0">
                    <h5 class="modal-title fw-semibold">New Coupon</h5>
                    <button type="button" class="btn-close" @onclick="() => _showCreate = false"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3 mb-3">
                        <div class="col-6">
                            <label class="form-label small fw-semibold">Coupon Code</label>
                            <input class="form-control text-uppercase fw-bold" @bind="_form.Code"
                                   placeholder="SUMMER20" style="letter-spacing:0.1em;" />
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-semibold">Name</label>
                            <input class="form-control" @bind="_form.Name" placeholder="Summer Sale 20%" />
                        </div>
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-6">
                            <label class="form-label small fw-semibold">Type</label>
                            <select class="form-select" @bind="_form.Type">
                                <option value="Percentage">Percentage (%)</option>
                                <option value="FixedAmount">Fixed Amount ($)</option>
                            </select>
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-semibold">Value</label>
                            <input type="number" class="form-control" @bind="_form.Value"
                                   min="0.01" step="0.01" />
                        </div>
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-6">
                            <label class="form-label small fw-semibold">Max Uses</label>
                            <input type="number" class="form-control" @bind="_form.MaxUsageCount" min="1" />
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-semibold">Expires At (optional)</label>
                            <input type="date" class="form-control" @bind="_form.ExpiresAt" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Min. Order Amount (optional)</label>
                        <input type="number" class="form-control" @bind="_form.MinOrderAmount"
                               min="0" step="0.01" placeholder="e.g. 50" />
                    </div>
                    <div class="form-check mb-3">
                        <input class="form-check-input" type="checkbox" @bind="_form.IsSingleUse" id="singleUse" />
                        <label class="form-check-label small" for="singleUse">
                            Single-use (deactivate after first redemption)
                        </label>
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button class="btn btn-outline-secondary" @onclick="() => _showCreate = false">Cancel</button>
                    <button class="btn btn-primary" @onclick="CreateAsync" disabled="@_creating">
                        @if (_creating)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        Create Coupon
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private Models.Common.PagedResult<CouponDto>? _coupons;
    private bool _loading = true;
    private bool _showCreate;
    private bool _creating;
    private int _page = 1;
    private string? _error;
    private string? _success;
    private CouponForm _form = new();

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _coupons = await DiscountService.GetCouponsAsync(_page);
        _loading = false;
    }

    private async Task OnPageChanged(int page)
    {
        _page = page;
        await LoadAsync();
    }

    private async Task CreateAsync()
    {
        _creating = true;
        _error = null;

        var request = new Models.Discounts.CreateCouponRequest(
            _form.Code.ToUpperInvariant(), _form.Name, _form.Type, _form.Value,
            _form.MaxUsageCount, _form.ExpiresAt, _form.MinOrderAmount, _form.IsSingleUse);

        var result = await DiscountService.CreateCouponAsync(request);
        if (result is not null)
        {
            _showCreate = false;
            _success = $"Coupon '{result.Code}' created.";
            _form = new();
            await LoadAsync();
        }
        else _error = "Failed to create coupon.";

        _creating = false;
    }

    private sealed class CouponForm
    {
        public string Code { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string Type { get; set; } = "Percentage";
        public decimal Value { get; set; }
        public int MaxUsageCount { get; set; } = 1;
        public DateTime? ExpiresAt { get; set; }
        public decimal? MinOrderAmount { get; set; }
        public bool IsSingleUse { get; set; }
    }
}
